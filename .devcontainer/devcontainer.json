// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/debian
{
	"name": "ydb-c-x86",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"service": "driver",
	"dockerComposeFile": "compose.yml",
	"workspaceFolder": "/workspaces/ydb-c-binding",
	"capAdd": [
		"SYS_PTRACE"
	],
	"securityOpt": [
		"seccomp=unconfined"
	],
	"features": {
		"ghcr.io/rocker-org/devcontainer-features/apt-packages:1": {},
		"ghcr.io/devcontainers-extra/features/zsh-plugins:0": {
			"plugins": "ssh-agent zsh-autosuggestions"
		}
	},
	// "initializeCommand": "mkdir -p ${localEnv:HOME}/.ccache && cd \"${localWorkspaceFolder}\" && git config --local user.email \"$(git config user.email)\" && git config --local user.name \"$(git config user.name)\"",
	// "postStartCommand": ".devcontainer/configure.sh",
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-vscode.cpptools-extension-pack",
				"ms-vscode.makefile-tools",
				"llvm-vs-code-extensions.vscode-clangd",
				"Gruntfuggly.todo-tree"
			],
			"settings": {
				"terminal.integrated.defaultProfile.linux": "zsh"
			}
		}
	},
	"remoteEnv": {
		"CCACHE_DIR": "/ccache",
		"CCACHE_MAXSIZE": "10G",
		"YDB_ENDPOINT": "grpc://localhost:2136",
		"YDB_DATABASE": "/local",
		"YDB_CPP_SDK_INSTALL_PREFIX": "/ydb-cpp-sdk/"
	},
	// FIXME: llm said that i don't need it since these are tracked by the compose
	// "mounts": [
	// 	"source=${localEnv:HOME}/.ccache,target=/root/.ccache,type=bind,consistency=cached"
	// ],
	"remoteUser": "root"
}